---
import {Clock, PlusSquareIcon, ShieldCheck, Star} from "@lucide/astro";
const response = [
    {
        icon: ShieldCheck,
        title: "Normes électriques",
        description: "Tous nos travaux respectent les normes NF C 15-100 en vigueur."
    },
    {
        icon: Clock,
        title: "Intervention rapide",
        description: "Réactivité maximale pour les urgences, planification souple pour les travaux."
    },
    {
        icon: PlusSquareIcon,
        title: "Devis clair & Transparent",
        description: "Pas de mauvaise surprise. Tout est détaillé avant le début du chantier"
    },
    {
        icon: Star,
        title: "Équipe spécialisée",
        description: "Des électriciens qualifiés avec conseils personnalisés sur chaque intervention."
    },
]
---

<section class="flex flex-col items-center justify-center">
    <div class="max-w-7xl mx-auto px-6 py-20 w-full">
        <div class="flex flex-col items-center gap-2 mb-16">
            <p class="text-md md:text-lg text-primary">Nos engagements</p>

            <h2 class="text-2xl md:text-4xl text-text font-serif font-bold text-center">Pourquoi choisir NETARA Électricité</h2>

            <p class="text-md font-normal text-text-muted max-w-2xl mx-auto text-center">
                Une équipe qualifiée, un travail soigné, des conseils honnêtes.
            </p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-2 w-full mb-2">
            {response.map((item) => (
                    <article class="flex flex-col items-start justify-start gap-2 p-6 rounded-md border border-border bg-card">
                        <div class="bg-primary-light rounded-md border border-primary-border flex justify-center items-center p-4">
                            <item.icon size={18} stroke-width={1.0} class="text-primary"/>
                        </div>
                        <p class="text-md md:text-lg font-semibold text-text">{item.title}</p>
                        <p class="text-xs md:text-sm font-semibold text-text-muted">{item.description}</p>
                    </article>
            ))}
        </div>
    </div>
</section>