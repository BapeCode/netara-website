---
import { Image } from "astro:assets"
import Elec from "../../assets/chantier_elec.png"
import Lumix from "../../assets/spot_lumix.png"

const urgence = ["Panne de courant", "Disjoncteur qui saute", "Court-circuit", "Prise défectueuse", "Tableau électrique en panne", "Éclairage défaillant"]
---

<section class="flex flex-col items-center justify-center">
    <div class="max-w-7xl mx-auto px-6 py-20 w-full">
        <div class="flex flex-col items-center gap-2 mb-16">
            <p class="text-md md:text-lg text-primary">Urgences</p>

            <h2 class="text-2xl md:text-4xl text-text font-serif font-bold text-center">Dépannage d'urgence</h2>

            <p class="text-md font-normal text-text-muted max-w-2xl mx-auto text-center">
                Panne soudaine ? On intervient vite. Voici les situations que nous traitons en priorité.
            </p>
        </div>


        <div class="flex flex-col items-start gap-2 w-full">
            <h2 class="text-lg md:text-2xl font-semibold text-text">Réponse rapide, <br/> intervention efficace</h2>
            <p class="text-sm text-text-muted">Contactez-nous, on se déplace. Chaque minute compte quand il s'agit d'électricité.</p>

            <div class="flex items-center gap-2 flex-col md:flex-row mb-8">
                <div class="relative rounded-2xl overflow-hidden w-full group" data-reveal="left">
                    <Image
                        src={Elec}
                        alt="Avant le nettoyage de la toiture"
                        class="w-full h-72 sm:h-80 object-cover transition-transform duration-700 group-hover:scale-105"
                    />
                    <div class="absolute bottom-0 left-0 p-6">
                        <span class="inline-block bg-yellow-500/80 text-card dark:text-text text-xs font-bold uppercase tracking-wider px-3 py-1 rounded-full mb-2">Chantier électrique</span>
                    </div>
                </div>

                <div class="relative rounded-2xl overflow-hidden w-full group" data-reveal="right" style="--reveal-delay: 120ms;">
                    <Image
                            src={Lumix}
                            alt="Après le nettoyage de la toiture"
                            class="w-full h-72 sm:h-80 object-cover transition-transform duration-700 group-hover:scale-105"
                    />
                    <div class="absolute bottom-0 left-0 p-6">
                        <span class="inline-block bg-yellow-500/80 text-card dark:text-text text-xs font-bold uppercase tracking-wider px-3 py-1 rounded-full mb-2">Spot Lumineux</span>
                    </div>
                </div>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-2 w-full">
                {urgence.map((item) => (
                    <article class="flex items-center justify-start gap-2 p-6 rounded-md border border-border bg-card">
                        <div class="h-4 w-4 rounded-full bg-danger"/>
                        <p class="text-md md:text-lg text-text-muted">{item}</p>
                    </article>
                ))}
            </div>
        </div>
    </div>
</section>
