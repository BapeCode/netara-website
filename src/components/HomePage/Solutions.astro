---
import {Bug, DropletsIcon, ShieldOff, TriangleAlertIcon} from "@lucide/astro";
import { Image } from "astro:assets";
import Before from "../../assets/before.png"
import After from "../../assets/after.png"

const constat = [
    {
        description: "Traces noires et salissures persistantes",
        icon: TriangleAlertIcon
    },
    {
        description: "Prolifération de mousses et lichens",
        icon: Bug
    },
    {
        description: "Tuiles devenues poreuses et fragiles",
        icon: DropletsIcon
    },
    {
        description: "Risques d'infiltrations et de dégâts",
        icon: ShieldOff
    },
]

const steps = [
    {
        title: "Diagnostic & nettoyage vapeur basse pression",
        description : "Élimination des mousses, lichens et algues à la vapeur basse pression. Procédé doux qui préserve vos tuiles, sans abîmer le support."
    },
    {
        title: "Méthode 100% écologique",
        description: "Aucun produit chimique, faible consommation d'eau. Respectueux de votre toiture, de vos plantes et de l'environnement."
    },
    {
        title: "Hydrofuge coloré (en option, fortement recommandé)",
        description: "Application d'un hydrofuge coloré pour imperméabiliser et raviver vos tuiles. Effet perlant durable, prolonge la vie de votre toiture de 10 à 15 ans."
    }
]
---

<section class="flex flex-col items-center justify-center" id="solutions">
    <div class="mx-auto max-w-7xl mb-16 px-6 py-20">
        <div class="flex flex-col items-center gap-2 mb-16" data-reveal="up">
            <p class="text-md md:text-lg text-primary">Le constat</p>

            <h2 class="text-2xl md:text-4xl text-text font-serif font-bold text-center">Votre toiture est-elle en danger ?</h2>

            <p class="text-md font-normal text-text-muted max-w-2xl mx-auto text-center">
                L'humidité, la pollution et le temps dégradent progressivement votre couverture. Un entretien régulier coûte
                <strong>10 fois moins cher</strong>
                qu'une réfection complète.
            </p>
        </div>

        <div class="flex flex-col md:flex-row items-center justify-center gap-4 mb-16">
            {constat.map((item, index) => (
                    <article
                        class="card-lift flex items-center gap-2 bg-card rounded-md border border-border p-6 w-full"
                        data-reveal="up"
                        style={`--reveal-delay: ${index * 90}ms;`}
                    >
                        <div class="flex items-center justify-center bg-danger/20 rounded-md p-2">
                            <item.icon class="text-danger" size={16}/>
                        </div>
                        <p class="text-text text-sm md:text-md font-normal">{item.description}</p>
                    </article>
            ))}
        </div>

        <div class="flex items-center gap-2 flex-col md:flex-row">
            <div class="relative rounded-2xl overflow-hidden w-full group" data-reveal="left">
                <Image
                    src={Before}
                    alt="Avant le nettoyage de la toiture"
                    class="w-full h-72 sm:h-80 object-cover transition-transform duration-700 group-hover:scale-105"
                />
                <div class="absolute bottom-0 left-0 p-6">
                    <span class="inline-block bg-danger text-card dark:text-text text-xs font-bold uppercase tracking-wider px-3 py-1 rounded-full mb-2">Avant</span>
                    <p class="text-sm text-card dark:text-text font-bold">Mousses, lichens et traces noires</p>
                </div>
            </div>

            <div class="relative rounded-2xl overflow-hidden w-full group" data-reveal="right" style="--reveal-delay: 120ms;">
                <Image
                        src={After}
                        alt="Après le nettoyage de la toiture"
                        class="w-full h-72 sm:h-80 object-cover transition-transform duration-700 group-hover:scale-105"
                />
                <div class="absolute bottom-0 left-0 p-6">
                    <span class="inline-block bg-success text-card dark:text-text text-xs font-bold uppercase tracking-wider px-3 py-1 rounded-full mb-2">Après</span>
                    <p class="text-sm text-card dark:text-text font-bold">Toiture protégée, effet perlant</p>
                </div>
            </div>
        </div>
    </div>

    <div class="w-full bg-surface flex flex-col">
        <div class="mx-auto max-w-7xl py-10 px-6">
            <div class="flex flex-col items-center gap-2 mb-16" data-reveal="up">
                <p class="text-md md:text-lg text-primary">Notre protocole</p>

                <h2 class="text-2xl md:text-4xl text-text font-serif font-bold text-center">3 étapes pour une toiture protégée</h2>

                <p class="text-md font-normal text-text-muted dark:text-text-muted max-w-2xl mx-auto text-center">
                    Un processus rigoureux, pensé pour durer et préserver vos équipements
                </p>
            </div>

            <div class="flex flex-col items-center gap-2">
                {steps.map((step, index) => (
                    <article
                        class="flex flex-col md:flex-row items-center gap-2 mb-8 pb-4 border-b border-border w-full hover:border-primary-border transition-colors duration-300"
                        data-reveal="left"
                        style={`--reveal-delay: ${index * 120}ms;`}
                    >
                        <div class="rounded-md border border-primary-border flex items-center justify-center h-10 w-10 bg-primary-light transition-transform duration-300 hover:scale-110 hover:rotate-3">
                            <p class="text-primary text-lg font-bold">0{index + 1}</p>
                        </div>

                        <div class="flex flex-col items-start">
                            <p class="uppercase text-xs font-semibold text-primary">étape 0{index + 1}</p>
                            <p class="text-md font-normal text-text">{step.title}</p>
                            <p class="text-sm font-normal text-text-muted">{step.description}</p>
                        </div>
                    </article>
                ))}
            </div>
        </div>
    </div>

</section>