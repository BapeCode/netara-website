---
import {type AstroComponent} from "@lucide/astro";

interface Props {
    title: string;
    description: string;
    informations: {label: string, icon: AstroComponent}[];
    ctas: {label: string, href: string}[]
}

const { title, description, informations, ctas } = Astro.props;
---

<section class="flex justify-center items-center w-full h-full bg-surface relative overflow-hidden">
    <div class="absolute inset-0 pointer-events-none -z-0">
        <div class="absolute top-1/4 -left-20 w-72 h-72 rounded-full bg-primary-light blur-3xl float-slow"></div>
        <div class="absolute bottom-1/4 -right-20 w-96 h-96 rounded-full bg-primary-light blur-3xl float-slow" style="animation-delay: -3s;"></div>
    </div>

    <div class="max-w-7xl mx-auto min-h-screen w-full flex items-center pt-20 relative z-10">
        <div class="flex flex-col items-center justify-center gap-4 w-full px-6">
            <h1 set:html={title} class="hero-anim text-4xl md:text-7xl font-bold text-text text-center" style="--anim-delay: 100ms;">
            </h1>
            <p class="hero-anim text-sm md:text-lg text-text-muted max-w-2xl text-center" style="--anim-delay: 250ms;">
                {description}
            </p>
            <div class="hero-anim flex flex-col md:flex-row items-center gap-2" style="--anim-delay: 400ms;">
                {ctas.map((item, index) => (
                        <a href={item.href}
                           class={index === 0
                               ? "px-6 py-3 bg-primary text-white rounded-md hover:bg-primary-dark hover:scale-[1.03] transition-all duration-300 w-full md:w-auto text-center shadow-md hover:shadow-lg"
                               : "border border-transparent px-6 py-3 bg-transparent text-text-muted rounded-md hover:border-primary-border hover:text-text transition-all duration-300 w-full md:w-auto text-center"
                           }
                        >
                            {item.label}
                        </a>
                ))}
            </div>

            <div class="hero-anim flex items-center gap-4" style="--anim-delay: 550ms;">
                {informations.map(item => (
                        <div class="flex items-center gap-0.5">
                            <item.icon size={12} class="text-text-muted"/>
                            <p class="text-xs text-text-muted">{item.label}</p>
                        </div>
                ))}
            </div>
        </div>
    </div>
</section>
