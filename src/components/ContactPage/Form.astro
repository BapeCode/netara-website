---
import { Clock, Mail, CheckCircle2, AlertCircle, X } from "@lucide/astro";


---

<section class="py-32 px-6 max-w-7xl mx-auto">
    <div class="flex flex-col md:flex-row gap-2">
        <article class="flex flex-col items-start justify-start gap-2 bg-card border border-border rounded-md p-6 flex-1" data-reveal="left">
            <h2 class="text-text font-semibold text-lg">Votre demande</h2>
            <span class="text-text-muted font-normal text-sm">Touts les champs marqués * sont obligatoires</span>

            <form id="contact-form" class="flex flex-col gap-4 w-full" method="POST" action="/api/contact">
                <div class="flex flex-col items-start gap-2">
                    <div class="flex items-center gap-2">
                        <p class="text-text-muted text-sm uppercase">Civilité</p>
                        <p class="text-danger text-sm">*</p>
                    </div>
                    <div class="flex items-center gap-2">
                        <div data-civ="M." class="flex items-center justify-center bg-surface border-border border rounded-md p-2">
                            <p class="text-text-muted text-sm uppercase">M.</p>
                        </div>
                        <div data-civ="Mme" class="flex items-center justify-center bg-surface border-border border rounded-md p-2">
                            <p class="text-text-muted text-sm uppercase">Mme</p>
                        </div>
                        <div data-civ="Autre" class="flex items-center justify-center bg-surface border-border border rounded-md p-2">
                            <p class="text-text-muted text-sm uppercase">Autre</p>
                        </div>
                    </div>
                </div>

                <div class="flex flex-col md:flex-row items-center gap-2 w-full">
                    <div class="flex flex-col items-start gap-2 w-full">
                        <div class="flex items-center gap-2">
                            <p class="text-text-muted text-sm uppercase">Nom</p>
                            <p class="text-danger text-sm">*</p>
                        </div>
                        <input
                                name="firstname"
                                placeholder="John Doe"
                                id="firstname"
                                type="text"
                                class="w-full appearance-none rounded-md px-2 py-1 bg-surface border border-border focus:border-primary-border outline-none ring-0"
                        >
                    </div>
                    <div class="flex flex-col items-start gap-2 w-full">
                        <div class="flex items-center gap-2">
                            <p class="text-text-muted text-sm uppercase">Commune</p>
                            <p class="text-danger text-sm">*</p>
                        </div>
                        <input
                                name="commune"
                                placeholder="Meyzieu"
                                id="commune"
                                type="text"
                                class="w-full appearance-none rounded-md px-2 py-1 bg-surface border border-border focus:border-primary-border outline-none ring-0"
                        >
                    </div>
                </div>

                <div class="flex flex-col md:flex-row items-center gap-2 w-full">
                    <div class="flex flex-col items-start gap-2 w-full">
                        <div class="flex items-center gap-2">
                            <p class="text-text-muted text-sm uppercase">Téléphone</p>
                            <p class="text-danger text-sm">*</p>
                        </div>
                        <input
                                name="phone"
                                placeholder="06 00 00 00 00"
                                id="phone"
                                type="text"
                                class="w-full appearance-none rounded-md px-2 py-1 bg-surface border border-border focus:border-primary-border outline-none ring-0"
                        >
                    </div>
                    <div class="flex flex-col items-start gap-2 w-full">
                        <div class="flex items-center gap-2">
                            <p class="text-text-muted text-sm uppercase">E-Mail</p>
                            <p class="text-danger text-sm">*</p>
                        </div>
                        <input
                                name="email"
                                placeholder="john.doe@gmail.com"
                                id="email"
                                type="email"
                                class="w-full appearance-none rounded-md px-2 py-1 bg-surface border border-border focus:border-primary-border outline-none ring-0"
                        >
                    </div>
                </div>

                <div class="flex flex-col items-start gap-2 w-full">
                    <div class="flex items-center gap-2">
                        <p class="text-text-muted text-sm uppercase">Services concerné</p>
                        <p class="text-danger text-sm">*</p>
                    </div>
                    <select name="contact_services" id="contact_services" class="w-full appearance-none rounded-md px-2 py-1 bg-surface border border-border focus:border-primary-border outline-none ring-0">
                        <option>Sélectionner...</option>
                        <option value="panneaux">Panneaux photovoltaïques</option>
                        <option value="electricity">Électricité</option>
                        <option value="nettoyage">Nettoyage BTP & Pro</option>
                        <option value="intervention">Intervention extrême</option>
                        <option class="other">Autre</option>
                    </select>
                </div>

                <input type="hidden" name="civilite" id="civilite-input" value="M."/>
                <div class="flex flex-col items-start gap-2 w-full">
                    <div class="flex items-center gap-2">
                        <p class="text-text-muted text-sm uppercase">Votre projet</p>
                        <p class="text-danger text-sm">*</p>
                    </div>
                    <input
                            name="description"
                            id="description"
                            placeholder="Décrivez votre besoin en détail..."
                            class="w-full max-h-32 min-h-10 appearance-none rounded-md px-2 py-1 bg-surface border border-border focus:border-primary-border outline-none ring-0"
                    />
                </div>

                <button id="contact-submit" type="submit" class="flex items-center justify-center bg-surface border-border border rounded-md w-full py-2 hover:bg-primary hover:text-white hover:border-primary transition-all duration-300 disabled:opacity-50 disabled:cursor-not-allowed">
                    <span id="contact-submit-label">Envoyer ma demande</span>
                </button>
            </form>
            <p class="text-xs font-light text-text-muted ">En soumettant, vous acceptez notre <a href="/confidentiality" class="text-primary">politique de confidentialité</a></p>
        </article>

        <div class="flex flex-col gap-2 flex-1">
            <article class="card-lift flex flex-col items-start justify-start gap-1 bg-card border border-border rounded-md p-4 flex-1" data-reveal="right" style="--reveal-delay: 0ms;">
                <div class="flex justify-center items-center border border-primary-border rounded-md p-4 bg-primary-light transition-transform duration-500 hover:rotate-6 hover:scale-110">
                    <Clock stroke-width={1.0} class="text-primary" size={24}/>
                </div>
                <p class="text-lg font-semibold text-text">Réponse rapide garantie</p>
                <p class="text-sm text-text-muted">Nous nous engageons à vous répondre dans les meilleurs délais. C'est notre promesse principale.</p>
            </article>
            <article class="card-lift flex flex-col items-start justify-start gap-1 bg-card border border-border rounded-md p-4 flex-1" data-reveal="right" style="--reveal-delay: 120ms;">
                <div class="flex justify-center items-center border border-primary-border rounded-md p-4 bg-primary-light transition-transform duration-500 hover:rotate-6 hover:scale-110">
                    <Mail stroke-width={1.0} class="text-primary" size={24}/>
                </div>
                <p class="text-lg font-semibold text-text">Contact direct</p>
                <p class="text-sm text-text-muted">Préférez-vous un contact direct ?</p>
                <a href="mailto:contact@netara.fr" class="text-md text-primary hover:underline">contact@netara.fr</a>
            </article>
            <article class="card-lift flex flex-col items-start justify-start gap-1 bg-card border border-border rounded-md p-4 flex-1" data-reveal="right" style="--reveal-delay: 240ms;">
                <div class="flex justify-center items-center border border-primary-border rounded-md p-4 bg-primary-light transition-transform duration-500 hover:rotate-6 hover:scale-110">
                    <Clock stroke-width={1.0} class="text-primary" size={24}/>
                </div>
                <p class="text-lg font-semibold text-text">Horaire</p>
                <div class="flex justify-between items-center w-full">
                    <p class="text-sm text-text-muted">Lundi - Jeudi</p>
                    <p class="text-sm text-text">09h00 - 19h00</p>
                </div>
                <div class="flex justify-between items-center w-full">
                    <p class="text-sm text-text-muted">Vendredi</p>
                    <p class="text-sm text-text">08h30 - 19h00</p>
                </div>
                <div class="flex justify-between items-center w-full">
                    <p class="text-sm text-text-muted">Week-End</p>
                    <p class="text-sm text-text">Sur devis</p>
                </div>
            </article>
        </div>
    </div>

    <!-- Toast notification (popup) -->
    <div
        id="contact-toast"
        role="status"
        aria-live="polite"
        class="fixed top-6 right-6 z-50 max-w-sm w-[calc(100%-3rem)] sm:w-auto pointer-events-none translate-x-[120%] opacity-0 transition-all duration-500 ease-out"
    >
        <div class="bg-card border rounded-md shadow-xl p-4 flex items-start gap-3 pointer-events-auto" id="contact-toast-card">
            <div class="flex items-center justify-center w-9 h-9 rounded-full shrink-0" id="contact-toast-icon-wrap">
                <span id="contact-toast-icon-success" class="hidden text-success">
                    <CheckCircle2 size={22} stroke-width={1.5}/>
                </span>
                <span id="contact-toast-icon-error" class="hidden text-danger">
                    <AlertCircle size={22} stroke-width={1.5}/>
                </span>
            </div>
            <div class="flex flex-col gap-1 flex-1 min-w-0">
                <p id="contact-toast-title" class="text-text font-semibold text-sm"></p>
                <p id="contact-toast-msg" class="text-text-muted text-xs break-words"></p>
            </div>
            <button
                id="contact-toast-close"
                type="button"
                aria-label="Fermer"
                class="text-text-muted hover:text-text transition-colors shrink-0"
            >
                <X size={16}/>
            </button>
        </div>
    </div>
</section>


<script>
    // Civilité buttons
    document.querySelectorAll<HTMLElement>('[data-civ]').forEach(btn => {
        btn.addEventListener('click', () => {
            document.querySelectorAll<HTMLElement>('[data-civ]').forEach((b) => {
                b.classList.remove('active', 'border-primary')
            })
            btn.classList.add('active', 'border-primary')
            const civInput = document.getElementById('civilite-input') as HTMLInputElement | null
            if (civInput && btn.dataset.civ) civInput.value = btn.dataset.civ
        })
    })

    // Form submit + toast feedback
    const form = document.getElementById('contact-form') as HTMLFormElement | null
    const submitBtn = document.getElementById('contact-submit') as HTMLButtonElement | null
    const submitLabel = document.getElementById('contact-submit-label')
    const toast = document.getElementById('contact-toast')
    const toastCard = document.getElementById('contact-toast-card')
    const toastTitle = document.getElementById('contact-toast-title')
    const toastMsg = document.getElementById('contact-toast-msg')
    const toastIconSuccess = document.getElementById('contact-toast-icon-success')
    const toastIconError = document.getElementById('contact-toast-icon-error')
    const toastClose = document.getElementById('contact-toast-close')

    let toastTimer: number | null = null

    const hideToast = () => {
        if (!toast) return
        toast.classList.remove('translate-x-0', 'opacity-100')
        toast.classList.add('translate-x-[120%]', 'opacity-0')
    }

    const showToast = (kind: 'success' | 'error', title: string, msg: string) => {
        if (!toast || !toastCard || !toastTitle || !toastMsg || !toastIconSuccess || !toastIconError) return
        if (toastTimer !== null) {
            window.clearTimeout(toastTimer)
            toastTimer = null
        }

        toastTitle.textContent = title
        toastMsg.textContent = msg

        toastCard.classList.remove('border-success/30', 'border-danger/30', 'border-border')
        if (kind === 'success') {
            toastCard.classList.add('border-success/30')
            toastIconSuccess.classList.remove('hidden')
            toastIconError.classList.add('hidden')
        } else {
            toastCard.classList.add('border-danger/30')
            toastIconError.classList.remove('hidden')
            toastIconSuccess.classList.add('hidden')
        }

        toast.classList.remove('translate-x-[120%]', 'opacity-0')
        toast.classList.add('translate-x-0', 'opacity-100')

        toastTimer = window.setTimeout(hideToast, kind === 'success' ? 5000 : 7000)
    }

    toastClose?.addEventListener('click', hideToast)

    form?.addEventListener('submit', async (event) => {
        event.preventDefault()
        if (!submitBtn || !submitLabel) return

        submitBtn.disabled = true
        const originalLabel = submitLabel.textContent
        submitLabel.textContent = 'Envoi en cours...'

        try {
            const response = await fetch('/api/contact', {
                method: 'POST',
                headers: { Accept: 'application/json' },
                body: new FormData(form)
            })
            const result = await response.json().catch(() => ({} as Record<string, unknown>))

            if (!response.ok) {
                const errMsg = typeof result.error === 'string' ? result.error : 'Une erreur est survenue.'
                throw new Error(errMsg)
            }

            showToast('success', 'Message envoyé !', 'Merci, nous vous répondons sous 24h.')
            form.reset()
            // Reset civilité visuel à M.
            document.querySelectorAll<HTMLElement>('[data-civ]').forEach((b) => b.classList.remove('active', 'border-primary'))
            const civInput = document.getElementById('civilite-input') as HTMLInputElement | null
            if (civInput) civInput.value = 'M.'
        } catch (error) {
            const message = error instanceof Error ? error.message : 'Une erreur est survenue.'
            showToast('error', "Échec de l'envoi", message)
        } finally {
            submitBtn.disabled = false
            submitLabel.textContent = originalLabel ?? 'Envoyer ma demande'
        }
    })
</script>