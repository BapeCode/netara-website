# SMTP — Hostinger (exemple)
# Hostinger : smtp.hostinger.com, port 465 (SSL) ou 587 (TLS)
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_USER=contact@netara.fr
SMTP_PASS=ton_mot_de_passe_ici

# Adresse expéditeur affichée (souvent identique à SMTP_USER)
